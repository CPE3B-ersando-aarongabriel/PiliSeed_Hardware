*.elf
*.bin
*.map
*.eep
*.hex
*.lst
*.sym
*.lss
*.o
*.d
build/
.build/

# >>>>> PlatformIO <<<<<
.pio/
.pioenvs/
.piolibdeps/

# >>>>> VS Code <<<<<
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# >>>>> macOS <<<<<
.DS_Store
.AppleDouble
.LSOverride
._*

# >>>>> Windows <<<<<
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# >>>>> Linux <<<<<
*~
.fuse_hidden*
.Trash-*
.nfs*

# >>>>> Logs <<<<<
*.log
logs/

# >>>>> Temporary Files <<<<<
*.tmp
*.temp
*.swp
*.swo
*~

